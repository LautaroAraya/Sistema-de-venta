# Ejemplo de variables de entorno para el sistema de licencias
# Copia este archivo a .env y reemplaza los valores según tu configuración

# ============================================
# CONFIGURACIÓN DE FIREBASE
# ============================================

# Ruta alternativa al archivo de credenciales (si prefieres no tenerlo en la raíz)
# Por defecto busca en la raíz del proyecto: serviceAccountKey.json
# FIREBASE_CREDENTIALS_PATH=/ruta/segura/a/serviceAccountKey.json

# ============================================
# CONFIGURACIÓN DE LICENCIAS (OPCIONAL)
# ============================================

# Nombre de la colección en Firestore donde se almacenan las licencias
# Por defecto: "licencias"
FIRESTORE_COLLECTION=licencias

# ============================================
# CONFIGURACIÓN DEBUG (SOLO DESARROLLO)
# ============================================

# Mostrar logs detallados de validación
# DEBUG_VALIDATION=true

# ============================================
# SINCRONIZACION DE REPARACIONES (API CENTRAL)
# ============================================

# Base URL de la API central externa (sin slash al final)
# Ej: https://mi-api-central.com
CENTRAL_API_BASE=

# API key de la API central para POST /api/reparaciones
CENTRAL_API_KEY=

# Ruta a la base SQLite local
# Si no se define, usa database/sistema_ventas.db
SQLITE_PATH=

# Timeout para requests de sincronización
CENTRAL_API_TIMEOUT=12

# Intervalo de sincronización automática en segundos (0 = desactivar)
CENTRAL_SYNC_INTERVAL_SECONDS=300

# API key opcional para proteger /sync-now y /sync-status (API local Flask)
WEB_API_KEY=

# URL local para test_sync_e2e.py
LOCAL_SYNC_API=http://127.0.0.1:8080

# ============================================
# NOTAS:
# - Este archivo NO debe subirse a Git (ya está en .gitignore)
# - Mantén este archivo fuera del control de versiones
# - Cambia los nombres de variables según tu preferencia
