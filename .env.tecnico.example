# Copia este archivo como .env.tecnico en el servidor de nube
# y ajusta valores reales.

# Backend de datos: sqlite o firestore
TECNICO_DATA_BACKEND=firestore

# Ruta SQLite en el servidor (solo si usas sqlite)
# SQLITE_PATH=database/sistema_ventas.db

# Usuario tecnico para login del panel
TECNICO_USER=tecnico

# Opcion 1 (simple): password en texto plano
# TECNICO_PASS=cambiar-esto

# Opcion 2 (recomendada): hash de password (Werkzeug scrypt/pbkdf2)
# Ejemplo para generar hash:
# python -c "from werkzeug.security import generate_password_hash as g; print(g('TuPassSegura123'))"
TECNICO_PASS_HASH=

# Secreto para firmar tokens (obligatorio en produccion)
TECNICO_APP_SECRET=cambiar-este-secreto-largo-y-random

# Duracion del token en segundos (8 horas por defecto)
TECNICO_TOKEN_MAX_AGE_SECONDS=28800

# CORS para frontend separado (1=activo, 0=desactivo)
TECNICO_ALLOW_CORS=1

# Mostrar contrasena/patron en panel tecnico (1=si, 0=no)
TECNICO_EXPOSE_UNLOCK_FIELDS=1

# Firestore (recomendado para Render gratis)
TECNICO_FIRESTORE_COLLECTION=reparaciones_publicas
# Opcion A: credenciales en archivo (si existe en el servidor)
# FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json
# Opcion B: credenciales JSON completas en variable (recomendado en cloud)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Puerto cloud (Render/Railway suele inyectar PORT automaticamente)
PORT=8080
